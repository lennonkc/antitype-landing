# Dependencies
node_modules/

# Build output — GitHub Actions builds & deploys this; never commit
dist/
dist-ssr/

# Local env / secrets (keep the committed example)
.env
.env.*
!.env.example
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript incremental build cache
*.tsbuildinfo

# Design docs & internal specs — not part of the public site
docs/

# Playwright verification screenshots (regenerated by scripts/verify-*.mjs)
scripts/shots/

# macOS
.DS_Store

# Editors
.idea/
.vscode/
*.swp
*.swo

# Local agent / tool state (regenerable; never commit)
.claude/
.gitnexus/
.superpowers/
